# Shortcut API Configuration
# Get your API token from: https://app.shortcut.com/settings/account/api-tokens
SHORTCUT_API_TOKEN=your_api_token_here

# Optional: Specify the number of days to look back for stories (default: 7)
DAYS_BACK=7

# Optional: Specify the number of results per page (default: 25, max: 100)
PAGE_SIZE=25

# Optional: Specify workflow state IDs to filter by (comma-separated, e.g., 500000001,500000002)
# Leave empty to fetch all states
WORKFLOW_STATE_IDS=

# Google Sheets integration
# The spreadsheet ID from the sheet URL (between /d/ and /edit)
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# Path to the service account JSON key file (keep this out of git!)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
# The scorecard tab within the spreadsheet (default: Dev)
GOOGLE_SHEETS_TAB_NAME=Dev
