# Shortcut API Configuration
# Get your API token from: https://app.shortcut.com/settings/account/api-tokens
SHORTCUT_API_TOKEN=your_api_token_here

# Optional: Specify the number of days to look back for stories (default: 7)
DAYS_BACK=7

# Optional: Specify workflow state IDs to filter by (comma-separated, e.g., 500000001,500000002)
# Leave empty to fetch all states
WORKFLOW_STATE_IDS=
