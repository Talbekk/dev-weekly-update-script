{
  "permissions": {
    "allow": [
      "Bash(npx vitest *)",
      "Bash(npm test *)",
      "Bash(npm -v)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx vitest run --silent"
          }
        ]
      }
    ]
  }
}
