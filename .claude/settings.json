{
  "permissions": {
    "allow": [
      "Bash(npx vitest *)",
      "Bash(npm test *)",
      "Bash(npm -v)",
      "Bash(perl -i -pe 's/^\\(    labels: \\\\[\\\\],\\)$/$1\\\\n    custom_fields: [],/ if $. >= 99 && $. <= 172' mocks/shortcut.ts)",
      "Bash(npm start *)",
      "Bash(xargs -I{} sh -c 'test -f \"{}\" && echo \"key file exists at: {}\" || echo \"MISSING: {}\"')",
      "Bash(npm install *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx vitest run --silent"
          }
        ]
      }
    ]
  }
}
